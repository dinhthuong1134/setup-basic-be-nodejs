{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "commonjs",
    "moduleResolution": "node",

    "target": "es2020",

    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },

  "include": ["src/**/*", "prisma.config.ts"],
}